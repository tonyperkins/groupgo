# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
SECRET_KEY=replace-with-32-random-chars-minimum

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/groupgo.db

# ─── Admin Credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploying

# ─── External APIs ────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_v3_api_key_here
SERPAPI_KEY=your_serpapi_key_here

# ─── Rate Limiting ────────────────────────────────────────────
SERPAPI_RATE_LIMIT_HOURS=12

# ─── Application Settings ─────────────────────────────────────
GROUP_SIZE=5

# ─── Portainer Access Token ─────────────────────────────────────
PORTAINER_ACCESS_TOKEN=portainer_access_token_here
PORTAINER_URL=http://portainer.homelab.lan/