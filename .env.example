# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
SECRET_KEY=replace-with-32-random-chars-minimum

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/groupgo.db

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your-email@example.com
ADMIN_NAME=Your Name

# ─── External APIs ────────────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_v3_api_key_here
SERPAPI_KEY=your_serpapi_key_here
GOOGLE_KG_API_KEY=your_google_kg_api_key_here

# ─── Rate Limiting ────────────────────────────────────────────
SERPAPI_RATE_LIMIT_HOURS=12

# ─── Application Settings ─────────────────────────────────────
GROUP_SIZE=5
GROUPGO_HOST_PORT=8001

# ─── Email (Gmail SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-gmail@gmail.com

# ─── Portainer Access Token ─────────────────────────────────────
PORTAINER_ACCESS_TOKEN=portainer_access_token_here
PORTAINER_URL=http://portainer.homelab.lan/